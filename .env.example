# Copia este archivo a `.env` y completa los valores.
# El .env real está en .gitignore (no se commitea).

# --- LLM: proveedor ---
# claude (default) o gemini. Conmuta todo el sistema con una línea.
LLM_PROVIDER=claude

# --- LLM: Anthropic / Claude (de pago; formato sk-ant-api03-...) ---
ANTHROPIC_API_KEY=
# Haiku 4.5 = el más barato de Claude ($1/$5 por 1M tokens)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- LLM: Google Gemini (tier gratuito; fallback) ---
GEMINI_API_KEY=
# LLM_MODEL_SQL=gemini-3.5-flash
# LLM_MODEL_INSIGHT=gemini-3.5-flash

# --- Reglas de negocio (opcional; override de los defaults) ---
# MARGEN_MINIMO=0.15
# MARGEN_OBJETIVO=0.25
# PARIDAD_TOLERANCIA=0.05

# --- Seguridad de queries (opcional) ---
# MAX_QUERY_ROWS=500
